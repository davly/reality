{
  "function": "EM.ResistorsInSeries",
  "cases": [
    {
      "description": "Three equal 100 ohm resistors -> 300",
      "inputs": {"resistances": [100.0, 100.0, 100.0]},
      "expected": 300.0,
      "tolerance": 1e-15
    },
    {
      "description": "Mixed: 10, 20, 30 -> 60",
      "inputs": {"resistances": [10.0, 20.0, 30.0]},
      "expected": 60.0,
      "tolerance": 1e-15
    },
    {
      "description": "Single resistor: 47 ohms",
      "inputs": {"resistances": [47.0]},
      "expected": 47.0,
      "tolerance": 1e-15
    },
    {
      "description": "Empty -> 0",
      "inputs": {"resistances": []},
      "expected": 0.0,
      "tolerance": 0
    }
  ]
}
