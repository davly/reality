{
  "function": "EM.RCTimeConstant",
  "cases": [
    {
      "description": "1kohm, 1uF -> 1ms",
      "inputs": {"R": 1000.0, "C": 0.000001},
      "expected": 0.001,
      "tolerance": 1e-15
    },
    {
      "description": "10kohm, 100uF -> 1s",
      "inputs": {"R": 10000.0, "C": 0.0001},
      "expected": 1.0,
      "tolerance": 1e-15
    },
    {
      "description": "1Mohm, 1pF -> 1us",
      "inputs": {"R": 1000000.0, "C": 1e-12},
      "expected": 1e-6,
      "tolerance": 1e-20
    },
    {
      "description": "Zero resistance -> 0",
      "inputs": {"R": 0.0, "C": 0.01},
      "expected": 0.0,
      "tolerance": 0
    }
  ]
}
