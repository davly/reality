{
  "function": "Calculus.SimpsonsRule",
  "cases": [
    {
      "description": "integral of x from 0 to 1 (expect 0.5)",
      "inputs": {"function": "x", "a": 0.0, "b": 1.0, "n": 100},
      "expected": 0.5,
      "tolerance": 1e-12
    },
    {
      "description": "integral of x^2 from 0 to 1 (expect 1/3)",
      "inputs": {"function": "x^2", "a": 0.0, "b": 1.0, "n": 100},
      "expected": 0.3333333333333333,
      "tolerance": 1e-12
    },
    {
      "description": "integral of x^3 from 0 to 1 (expect 0.25)",
      "inputs": {"function": "x^3", "a": 0.0, "b": 1.0, "n": 100},
      "expected": 0.25,
      "tolerance": 1e-10
    },
    {
      "description": "integral of sin(x) from 0 to pi (expect 2)",
      "inputs": {"function": "sin", "a": 0.0, "b": 3.141592653589793, "n": 100},
      "expected": 2.0,
      "tolerance": 1e-7
    },
    {
      "description": "integral of exp(x) from 0 to 1 (expect e-1)",
      "inputs": {"function": "exp", "a": 0.0, "b": 1.0, "n": 100},
      "expected": 1.718281828459045,
      "tolerance": 1e-10
    },
    {
      "description": "integral of cos(x) from 0 to pi/2 (expect 1)",
      "inputs": {"function": "cos", "a": 0.0, "b": 1.5707963267948966, "n": 100},
      "expected": 1.0,
      "tolerance": 1e-8
    },
    {
      "description": "integral of constant 5 from 0 to 3 (expect 15)",
      "inputs": {"function": "5", "a": 0.0, "b": 3.0, "n": 10},
      "expected": 15.0,
      "tolerance": 1e-12
    },
    {
      "description": "integral of 1/x from 1 to e (expect 1)",
      "inputs": {"function": "1/x", "a": 1.0, "b": 2.718281828459045, "n": 100},
      "expected": 1.0,
      "tolerance": 1e-8
    }
  ]
}
