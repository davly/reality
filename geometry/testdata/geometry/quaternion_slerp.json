{
  "function": "Geometry.QuatSlerp",
  "cases": [
    {
      "description": "slerp at t=0 returns first quaternion",
      "inputs": {
        "a": [1, 0, 0, 0],
        "b": [0.70710678118654757, 0, 0, 0.70710678118654746],
        "t": 0.0
      },
      "expected": [1, 0, 0, 0],
      "tolerance": 1e-15
    },
    {
      "description": "slerp at t=1 returns second quaternion",
      "inputs": {
        "a": [1, 0, 0, 0],
        "b": [0.70710678118654757, 0, 0, 0.70710678118654746],
        "t": 1.0
      },
      "expected": [0.70710678118654757, 0, 0, 0.70710678118654746],
      "tolerance": 1e-12
    },
    {
      "description": "slerp identity to 90-deg Z at t=0.5 (45-deg Z)",
      "inputs": {
        "a": [1, 0, 0, 0],
        "b": [0.70710678118654757, 0, 0, 0.70710678118654746],
        "t": 0.5
      },
      "expected": [0.92387953251128685, 0, 0, 0.38268343236508978],
      "tolerance": 1e-12
    },
    {
      "description": "slerp identity to 90-deg Z at t=0.25",
      "inputs": {
        "a": [1, 0, 0, 0],
        "b": [0.70710678118654757, 0, 0, 0.70710678118654746],
        "t": 0.25
      },
      "expected": [0.98078528040323054, 0, 0, 0.19509032201612825],
      "tolerance": 1e-12
    },
    {
      "description": "slerp identity to 90-deg Z at t=0.75",
      "inputs": {
        "a": [1, 0, 0, 0],
        "b": [0.70710678118654757, 0, 0, 0.70710678118654746],
        "t": 0.75
      },
      "expected": [0.83146961230254535, 0, 0, 0.55557023301960218],
      "tolerance": 1e-12
    },
    {
      "description": "slerp identity to itself returns identity",
      "inputs": {
        "a": [1, 0, 0, 0],
        "b": [1, 0, 0, 0],
        "t": 0.5
      },
      "expected": [1, 0, 0, 0],
      "tolerance": 1e-15
    },
    {
      "description": "slerp between X and Z rotations at t=0.5",
      "inputs": {
        "a": [0.70710678118654757, 0.70710678118654746, 0, 0],
        "b": [0.70710678118654757, 0, 0, 0.70710678118654746],
        "t": 0.5
      },
      "expected": [0.81649658092772603, 0.40824829046386296, 0, 0.40824829046386296],
      "tolerance": 1e-12
    },
    {
      "description": "slerp with opposite-hemisphere quaternion (negative dot) takes shortest arc",
      "inputs": {
        "a": [1, 0, 0, 0],
        "b": [-0.70710678118654757, 0, 0, -0.70710678118654746],
        "t": 0.5
      },
      "expected": [0.92387953251128685, 0, 0, 0.38268343236508978],
      "tolerance": 1e-12
    },
    {
      "description": "slerp identity to diagonal 45-deg rotation at t=0.5",
      "inputs": {
        "a": [1, 0, 0, 0],
        "b": [0.92387953251128674, 0.27059805007309845, 0.27059805007309845, 0],
        "t": 0.5
      },
      "expected": [0.98078528040323021, 0.13794968964147145, 0.13794968964147145, 0],
      "tolerance": 1e-12
    },
    {
      "description": "slerp between X-90 and Y-180 at t=0.5",
      "inputs": {
        "a": [0.70710678118654757, 0.70710678118654746, 0, 0],
        "b": [6.1232339957367574e-17, 0, 1, 0],
        "t": 0.5
      },
      "expected": [0.5, 0.49999999999999989, 0.70710678118654746, 0],
      "tolerance": 1e-12
    }
  ]
