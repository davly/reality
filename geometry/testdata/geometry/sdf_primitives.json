{
  "function": "Geometry.SDFPrimitives",
  "cases": [
    {
      "description": "sphere: point outside (2,0,0), center origin, r=1",
      "inputs": {"p": [2, 0, 0], "center": [0, 0, 0], "radius": 1.0, "primitive": "sphere"},
      "expected": 1.0,
      "tolerance": 1e-15
    },
    {
      "description": "sphere: point at center, r=1 (inside)",
      "inputs": {"p": [0, 0, 0], "center": [0, 0, 0], "radius": 1.0, "primitive": "sphere"},
      "expected": -1.0,
      "tolerance": 1e-15
    },
    {
      "description": "sphere: point on surface (1,0,0), r=1",
      "inputs": {"p": [1, 0, 0], "center": [0, 0, 0], "radius": 1.0, "primitive": "sphere"},
      "expected": 0.0,
      "tolerance": 1e-15
    },
    {
      "description": "sphere: offset center (1,2,3), point at center, r=2",
      "inputs": {"p": [1, 2, 3], "center": [1, 2, 3], "radius": 2.0, "primitive": "sphere"},
      "expected": -2.0,
      "tolerance": 1e-15
    },
    {
      "description": "sphere: diagonal point (1,1,1), center origin, r=1",
      "inputs": {"p": [1, 1, 1], "center": [0, 0, 0], "radius": 1.0, "primitive": "sphere"},
      "expected": 0.73205080756887719,
      "tolerance": 1e-12
    },
    {
      "description": "box: point outside along x-axis",
      "inputs": {"p": [2, 0, 0], "center": [0, 0, 0], "halfExtents": [1, 1, 1], "primitive": "box"},
      "expected": 1.0,
      "tolerance": 1e-15
    },
    {
      "description": "box: point at center (inside)",
      "inputs": {"p": [0, 0, 0], "center": [0, 0, 0], "halfExtents": [1, 1, 1], "primitive": "box"},
      "expected": -1.0,
      "tolerance": 1e-15
    },
    {
      "description": "box: point at corner (2,2,2), half=(1,1,1)",
      "inputs": {"p": [2, 2, 2], "center": [0, 0, 0], "halfExtents": [1, 1, 1], "primitive": "box"},
      "expected": 1.7320508075688772,
      "tolerance": 1e-12
    },
    {
      "description": "box: inside asymmetric box",
      "inputs": {"p": [0.5, 1, 2], "center": [0, 0, 0], "halfExtents": [1, 2, 3], "primitive": "box"},
      "expected": -0.5,
      "tolerance": 1e-15
    },
    {
      "description": "capsule: point perpendicular to segment midpoint",
      "inputs": {"p": [0.5, 0.5, 0], "a": [0, 0, 0], "b": [0, 1, 0], "radius": 0.5, "primitive": "capsule"},
      "expected": 0.0,
      "tolerance": 1e-15
    },
    {
      "description": "capsule: point along segment axis",
      "inputs": {"p": [1, 0, 0], "a": [0, -1, 0], "b": [0, 1, 0], "radius": 0.5, "primitive": "capsule"},
      "expected": 0.5,
      "tolerance": 1e-15
    },
    {
      "description": "torus: point on ring center (inside minor circle)",
      "inputs": {"p": [2, 0, 0], "center": [0, 0, 0], "majorR": 2.0, "minorR": 0.5, "primitive": "torus"},
      "expected": -0.5,
      "tolerance": 1e-15
    }
  ]
}
