{
  "function": "reliability.ParallelAvailability",
  "cases": [
    {
      "description": "two components 0.9,0.8 active redundancy",
      "inputs": {
        "a": [
          0.9,
          0.8
        ]
      },
      "expected": 0.98,
      "tolerance": 1e-12
    },
    {
      "description": "dual 0.99 redundancy -> 0.9999",
      "inputs": {
        "a": [
          0.99,
          0.99
        ]
      },
      "expected": 0.9999,
      "tolerance": 1e-12
    },
    {
      "description": "triple 0.9 redundancy",
      "inputs": {
        "a": [
          0.9,
          0.9,
          0.9
        ]
      },
      "expected": 0.999,
      "tolerance": 1e-12
    },
    {
      "description": "single component = itself",
      "inputs": {
        "a": [
          0.95
        ]
      },
      "expected": 0.95,
      "tolerance": 1e-12
    },
    {
      "description": "empty parallel = 0.0",
      "inputs": {
        "a": []
      },
      "expected": 0.0,
      "tolerance": 1e-15
    },
    {
      "description": "one perfect branch -> 1.0",
      "inputs": {
        "a": [
          1.0,
          0.5
        ]
      },
      "expected": 1.0,
      "tolerance": 1e-15
    },
    {
      "description": "one dead branch is neutral",
      "inputs": {
        "a": [
          0.0,
          0.9
        ]
      },
      "expected": 0.9,
      "tolerance": 1e-12
    }
  ]
}