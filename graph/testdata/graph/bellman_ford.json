{
  "function": "graph.BellmanFord",
  "cases": [
    {
      "description": "simple_positive_weights",
      "inputs": {
        "n": 4,
        "edges": [[0, 1, 4.0], [0, 2, 1.0], [1, 2, 1.0], [2, 1, 2.0], [1, 3, 1.0], [2, 3, 5.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 3.0, 1.0, 4.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "negative_weight_no_cycle",
      "inputs": {
        "n": 3,
        "edges": [[0, 1, 4.0], [0, 2, 5.0], [1, 2, -3.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 4.0, 1.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "negative_cycle",
      "inputs": {
        "n": 3,
        "edges": [[0, 1, 1.0], [1, 2, -2.0], [2, 0, 0.0]],
        "source": 0
      },
      "expected": {"neg_cycle": true},
      "tolerance": 0
    },
    {
      "description": "single_node",
      "inputs": {
        "n": 1,
        "edges": [],
        "source": 0
      },
      "expected": {"dist": [0.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "unreachable_node",
      "inputs": {
        "n": 3,
        "edges": [[0, 1, 5.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 5.0, "Inf"], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "linear_chain",
      "inputs": {
        "n": 4,
        "edges": [[0, 1, 2.0], [1, 2, 3.0], [2, 3, 4.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 2.0, 5.0, 9.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "diamond_graph",
      "inputs": {
        "n": 4,
        "edges": [[0, 1, 10.0], [0, 2, 3.0], [1, 3, 2.0], [2, 1, 4.0], [2, 3, 8.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 7.0, 3.0, 9.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "two_paths_negative_shorter",
      "inputs": {
        "n": 4,
        "edges": [[0, 1, 1.0], [1, 3, 2.0], [0, 2, 5.0], [2, 3, -4.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 1.0, 5.0, 1.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "all_zero_weights",
      "inputs": {
        "n": 3,
        "edges": [[0, 1, 0.0], [1, 2, 0.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 0.0, 0.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "source_not_zero",
      "inputs": {
        "n": 3,
        "edges": [[0, 1, 1.0], [1, 2, 2.0]],
        "source": 1
      },
      "expected": {"dist": ["Inf", 0.0, 2.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "star_graph",
      "inputs": {
        "n": 5,
        "edges": [[0, 1, 3.0], [0, 2, 1.0], [0, 3, 4.0], [0, 4, 2.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 3.0, 1.0, 4.0, 2.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "reverse_star",
      "inputs": {
        "n": 5,
        "edges": [[1, 0, 3.0], [2, 0, 1.0], [3, 0, 4.0], [4, 0, 2.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, "Inf", "Inf", "Inf", "Inf"], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "self_loop",
      "inputs": {
        "n": 2,
        "edges": [[0, 0, -1.0], [0, 1, 5.0]],
        "source": 0
      },
      "expected": {"neg_cycle": true},
      "tolerance": 0
    },
    {
      "description": "complete_3_positive",
      "inputs": {
        "n": 3,
        "edges": [[0, 1, 3.0], [0, 2, 5.0], [1, 0, 2.0], [1, 2, 1.0], [2, 0, 4.0], [2, 1, 6.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 3.0, 4.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "fractional_weights",
      "inputs": {
        "n": 3,
        "edges": [[0, 1, 0.5], [1, 2, 0.3]],
        "source": 0
      },
      "expected": {"dist": [0.0, 0.5, 0.8], "neg_cycle": false},
      "tolerance": 1e-14
    },
    {
      "description": "large_negative_chain",
      "inputs": {
        "n": 4,
        "edges": [[0, 1, -1.0], [1, 2, -1.0], [2, 3, -1.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, -1.0, -2.0, -3.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "two_nodes_forward_back",
      "inputs": {
        "n": 2,
        "edges": [[0, 1, 1.0], [1, 0, 1.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 1.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "parallel_edges",
      "inputs": {
        "n": 2,
        "edges": [[0, 1, 10.0], [0, 1, 3.0], [0, 1, 7.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 3.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "five_node_dag_negative",
      "inputs": {
        "n": 5,
        "edges": [[0, 1, 6.0], [0, 2, 7.0], [1, 2, 8.0], [1, 3, 5.0], [1, 4, -4.0], [2, 3, -3.0], [2, 4, 9.0], [3, 4, 7.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 6.0, 7.0, 4.0, 2.0], "neg_cycle": false},
      "tolerance": 1e-15
    },
    {
      "description": "isolated_component",
      "inputs": {
        "n": 4,
        "edges": [[0, 1, 1.0], [2, 3, 1.0]],
        "source": 0
      },
      "expected": {"dist": [0.0, 1.0, "Inf", "Inf"], "neg_cycle": false},
      "tolerance": 1e-15
    }
  ]
}
