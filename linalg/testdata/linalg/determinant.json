{
  "function": "Linalg.Determinant",
  "cases": [
    {
      "description": "1x1 scalar",
      "inputs": {"A": [7.0], "n": 1},
      "expected": 7.0,
      "tolerance": 1e-15
    },
    {
      "description": "2x2 ad-bc formula: [[1,2],[3,4]]",
      "inputs": {"A": [1, 2, 3, 4], "n": 2},
      "expected": -2.0,
      "tolerance": 1e-12
    },
    {
      "description": "2x2 identity",
      "inputs": {"A": [1, 0, 0, 1], "n": 2},
      "expected": 1.0,
      "tolerance": 1e-15
    },
    {
      "description": "3x3 known value: [[6,1,1],[4,-2,5],[2,8,7]]",
      "inputs": {"A": [6, 1, 1, 4, -2, 5, 2, 8, 7], "n": 3},
      "expected": -306.0,
      "tolerance": 1e-10
    },
    {
      "description": "3x3 singular matrix (row 3 = row 1 + row 2)",
      "inputs": {"A": [1, 2, 3, 4, 5, 6, 5, 7, 9], "n": 3},
      "expected": 0.0,
      "tolerance": 1e-10
    },
    {
      "description": "3x3 diagonal matrix",
      "inputs": {"A": [2, 0, 0, 0, 3, 0, 0, 0, 5], "n": 3},
      "expected": 30.0,
      "tolerance": 1e-12
    },
    {
      "description": "2x2 negative determinant [[0,1],[1,0]]",
      "inputs": {"A": [0, 1, 1, 0], "n": 2},
      "expected": -1.0,
      "tolerance": 1e-15
    },
    {
      "description": "3x3 identity",
      "inputs": {"A": [1, 0, 0, 0, 1, 0, 0, 0, 1], "n": 3},
      "expected": 1.0,
      "tolerance": 1e-15
    }
  ]
}
