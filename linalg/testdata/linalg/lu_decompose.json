{
  "function": "Linalg.LUDecompose",
  "cases": [
    {
      "description": "1x1 trivial matrix",
      "inputs": {"A": [5.0], "n": 1},
      "expected": {"L": [1.0], "U": [5.0], "det": 5.0},
      "tolerance": 1e-15
    },
    {
      "description": "2x2 identity matrix",
      "inputs": {"A": [1, 0, 0, 1], "n": 2},
      "expected": {"L": [1, 0, 0, 1], "U": [1, 0, 0, 1], "det": 1.0},
      "tolerance": 1e-15
    },
    {
      "description": "2x2 known decomposition — [[2,3],[4,7]]",
      "inputs": {"A": [2, 3, 4, 7], "n": 2},
      "expected": {"det": 2.0},
      "tolerance": 1e-12
    },
    {
      "description": "3x3 known matrix — [[2,1,1],[4,3,3],[8,7,9]]",
      "inputs": {"A": [2, 1, 1, 4, 3, 3, 8, 7, 9], "n": 3},
      "expected": {"det": 4.0},
      "tolerance": 1e-12
    },
    {
      "description": "3x3 upper triangular",
      "inputs": {"A": [1, 2, 3, 0, 4, 5, 0, 0, 6], "n": 3},
      "expected": {"det": 24.0},
      "tolerance": 1e-12
    },
    {
      "description": "3x3 lower triangular",
      "inputs": {"A": [2, 0, 0, 3, 4, 0, 5, 6, 7], "n": 3},
      "expected": {"det": 56.0},
      "tolerance": 1e-12
    },
    {
      "description": "3x3 negative determinant — row swap needed",
      "inputs": {"A": [0, 1, 0, 1, 0, 0, 0, 0, 1], "n": 3},
      "expected": {"det": -1.0},
      "tolerance": 1e-15
    },
    {
      "description": "4x4 known Hilbert-like matrix",
      "inputs": {"A": [1, 0.5, 0.333333333333333, 0.25, 0.5, 0.333333333333333, 0.25, 0.2, 0.333333333333333, 0.25, 0.2, 0.166666666666667, 0.25, 0.2, 0.166666666666667, 0.142857142857143], "n": 4},
      "expected": {"det": 1.6534391534391452e-07},
      "tolerance": 1e-12
    }
  ]
}
