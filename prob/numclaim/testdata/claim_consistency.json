        {"claimIndex": 2, "claim": 520, "matched": false, "transform": "", "roundDP": -1, "truthIndex": 2, "truth": 188.8}
      ]
    },
    {
      "description": "look-through weights all stated as percentages",
      "claims": [80, 15, 5],
      "truths": [0.8, 0.15, 0.05],
