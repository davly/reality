      "description": "nTrials=1 reduces to PSR against zero benchmark",
      "inputs": {
        "observedSR": 0.2,
        "n": 250,
        "skew": 0.0,
        "kurt": 3.0,
        "nTrials": 1,
        "srVariance": 0.09
      },
      "expected": 0.9991105301385781,
      "tolerance": 1e-06
    },
    {
      "description": "V=0 reduces to PSR against zero benchmark",
